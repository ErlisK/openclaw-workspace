{
  "functions": {
    "app/api/browser/start/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/browser/screenshot/route.ts": { "maxDuration": 30, "memory": 1024 },
    "app/api/browser/action/route.ts": { "maxDuration": 30, "memory": 1024 },
    "app/api/browser/stop/route.ts": { "maxDuration": 10, "memory": 512 }
  },
  "crons": [
    {
      "path": "/api/cron/expire-jobs",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-drafts",
      "schedule": "0 3 * * *"
    }
  ]
}
