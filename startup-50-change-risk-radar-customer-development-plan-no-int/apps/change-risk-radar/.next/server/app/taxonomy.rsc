6:["$","$L14",null,{"taxonomy":[{"id":"LEGAL-001","category":"legal","title":"Terms of Service Material Update","description":"Vendor modifies ToS in ways that affect liability, data ownership, auto-renewal terms, or indemnification.","risk_level":"high","detection_method":"tos_diff","typical_lead_time":"0–30 days","examples":["Slack updates ToS to allow training AI on messages","Zoom ToS arbitration clause change"],"impacted_roles":["Legal","CFO","CEO"],"vendors":["Slack","Zoom","Google Workspace","Microsoft 365","Dropbox"],"detection_urls":["https://slack.com/intl/en-us/terms-of-service","https://explore.zoom.us/en/terms/"],"created_at":"2026-04-04T18:22:06.037902+00:00","updated_at":"2026-04-04T18:22:06.037902+00:00"},{"id":"LEGAL-002","category":"legal","title":"Privacy Policy Change Affecting Data Processing","description":"Vendor updates how they collect, share, or process user/company data.","risk_level":"high","detection_method":"tos_diff","typical_lead_time":"0–30 days","examples":["Google Workspace updates data retention clauses","HubSpot changes third-party data sharing"],"impacted_roles":["Legal","Compliance","DPO"],"vendors":["Google Workspace","Salesforce","HubSpot","Zoom","Microsoft 365"],"detection_urls":["https://policies.google.com/privacy","https://legal.hubspot.com/privacy-policy"],"created_at":"2026-04-04T18:22:06.104386+00:00","updated_at":"2026-04-04T18:22:06.104386+00:00"},{"id":"LEGAL-003","category":"legal","title":"Data Processing Agreement (DPA) Update","description":"Vendor changes subprocessors, data locations, or GDPR/CCPA data processing terms.","risk_level":"high","detection_method":"tos_diff","typical_lead_time":"30 days","examples":["Stripe adds new subprocessors in APAC","Okta DPA update for EU data residency"],"impacted_roles":["Legal","DPO","Compliance"],"vendors":["Stripe","Okta","Auth0","Salesforce","HubSpot"],"detection_urls":["https://stripe.com/legal/dpa","https://www.okta.com/privacy/"],"created_at":"2026-04-04T18:22:06.205986+00:00","updated_at":"2026-04-04T18:22:06.205986+00:00"},{"id":"LEGAL-004","category":"legal","title":"Acceptable Use Policy Change","description":"Vendor restricts what content, industries, or use cases are permitted on their platform.","risk_level":"high","detection_method":"tos_diff","typical_lead_time":"0–30 days","examples":["Stripe bans new merchant category","Twilio restricts SMS for certain use cases"],"impacted_roles":["Legal","Product","Ops"],"vendors":["Stripe","Twilio","PayPal","Shopify","AWS"],"detection_urls":["https://stripe.com/restricted-businesses","https://www.twilio.com/legal/aup"],"created_at":"2026-04-04T18:22:06.269092+00:00","updated_at":"2026-04-04T18:22:06.269092+00:00"},{"id":"LEGAL-005","category":"legal","title":"Compliance Certification Lapse or Change","description":"Vendor loses or changes a key compliance certification (SOC 2, ISO 27001, HIPAA BAA).","risk_level":"high","detection_method":"trust_page_diff","typical_lead_time":"0 days (immediate)","examples":["Vendor SOC 2 Type II lapses","AWS adds new HIPAA-eligible services"],"impacted_roles":["CISO","Legal","Compliance"],"vendors":["AWS","Stripe","Google Workspace","Okta","Salesforce"],"detection_urls":["https://aws.amazon.com/compliance/","https://stripe.com/docs/security"],"created_at":"2026-04-04T18:22:06.347445+00:00","updated_at":"2026-04-04T18:22:06.347445+00:00"},{"id":"LEGAL-006","category":"legal","title":"Auto-Renewal or Contract Term Change","description":"Vendor changes default contract length, auto-renewal windows, or cancellation notice requirements.","risk_level":"medium","detection_method":"tos_diff","typical_lead_time":"30–90 days","examples":["SaaS vendor changes annual auto-renewal notice from 30 to 15 days"],"impacted_roles":["Finance","Legal","Procurement"],"vendors":["Salesforce","HubSpot","Zendesk","Adobe","DocuSign"],"detection_urls":[],"created_at":"2026-04-04T18:22:06.422031+00:00","updated_at":"2026-04-04T18:22:06.422031+00:00"},{"id":"OPS-001","category":"operational","title":"API Endpoint Deprecation Notice","description":"Vendor announces retirement of one or more API endpoints with a specific sunset date.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"3–12 months","examples":["Stripe deprecates Sources API in favor of PaymentIntents","Twilio retires legacy REST API version"],"impacted_roles":["Engineering","CTO"],"vendors":["Stripe","Twilio","Shopify","Salesforce","HubSpot"],"detection_urls":["https://stripe.com/docs/changelog","https://www.twilio.com/changelog"],"created_at":"2026-04-04T18:22:06.483052+00:00","updated_at":"2026-04-04T18:22:06.483052+00:00"},{"id":"OPS-002","category":"operational","title":"Webhook Payload Format Change","description":"Vendor changes the structure, fields, or delivery mechanism of webhook events.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["Stripe changes webhook event object structure","GitHub changes webhook payload for push events"],"impacted_roles":["Engineering","DevOps"],"vendors":["Stripe","GitHub","Shopify","Intercom","PagerDuty"],"detection_urls":["https://stripe.com/docs/changelog","https://github.blog/changelog/"],"created_at":"2026-04-04T18:22:06.54379+00:00","updated_at":"2026-04-04T18:22:06.54379+00:00"},{"id":"OPS-003","category":"operational","title":"SDK Major Version Breaking Change","description":"Vendor releases a major SDK version with breaking changes requiring code migration.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"6–12 months","examples":["Stripe SDK v12 removes legacy Node.js patterns","AWS SDK v3 mandatory migration"],"impacted_roles":["Engineering","CTO"],"vendors":["Stripe","AWS","Twilio","Salesforce","Okta"],"detection_urls":["https://github.com/stripe/stripe-node/releases","https://github.com/aws/aws-sdk-js-v3/releases"],"created_at":"2026-04-04T18:22:06.633508+00:00","updated_at":"2026-04-04T18:22:06.633508+00:00"},{"id":"OPS-004","category":"operational","title":"OAuth Scope or Permission Change","description":"Vendor changes required OAuth scopes, permission grants, or access token behavior.","risk_level":"high","detection_method":"docs_diff","typical_lead_time":"30–90 days","examples":["Google Workspace restricts Sheets API scopes","Slack changes OAuth 2.0 scope requirements"],"impacted_roles":["Engineering","Security"],"vendors":["Google Workspace","Slack","GitHub","Salesforce","HubSpot"],"detection_urls":["https://developers.google.com/identity/protocols/oauth2/scopes","https://api.slack.com/scopes"],"created_at":"2026-04-04T18:22:06.706489+00:00","updated_at":"2026-04-04T18:22:06.706489+00:00"},{"id":"OPS-005","category":"operational","title":"Service Region or Data Center Change","description":"Vendor adds, removes, or migrates service regions affecting latency or data residency.","risk_level":"medium","detection_method":"changelog_scrape","typical_lead_time":"60–180 days","examples":["AWS deprecates us-east-1 availability zone","Shopify migrates EU merchants to new data center"],"impacted_roles":["Engineering","Legal","Compliance"],"vendors":["AWS","GCP","Azure","Shopify","Cloudflare"],"detection_urls":["https://aws.amazon.com/new/","https://shopify.dev/changelog"],"created_at":"2026-04-04T18:22:06.772844+00:00","updated_at":"2026-04-04T18:22:06.772844+00:00"},{"id":"OPS-006","category":"operational","title":"Checkout Flow or UX Breaking Change","description":"E-commerce platform modifies checkout flow in ways that break custom integrations or conversion tracking.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["Shopify deprecates checkout.liquid for checkout extensibility API","Stripe Elements design system change"],"impacted_roles":["Engineering","Product","Growth"],"vendors":["Shopify","Stripe","WooCommerce","BigCommerce"],"detection_urls":["https://shopify.dev/changelog","https://stripe.com/docs/changelog"],"created_at":"2026-04-04T18:22:06.836105+00:00","updated_at":"2026-04-04T18:22:06.836105+00:00"},{"id":"OPS-007","category":"operational","title":"App Permission or Marketplace Policy Change","description":"App store or marketplace changes what data third-party apps can access or required permission scopes.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–60 days","examples":["Shopify app permissions model change","Google Workspace Marketplace policy update"],"impacted_roles":["Engineering","Product","Legal"],"vendors":["Shopify","Google Workspace","Salesforce AppExchange","HubSpot App Marketplace"],"detection_urls":["https://shopify.dev/docs/apps/build/authentication-authorization/access-scopes"],"created_at":"2026-04-04T18:22:06.924307+00:00","updated_at":"2026-04-04T18:22:06.924307+00:00"},{"id":"OPS-008","category":"operational","title":"Email/SMS Deliverability Policy Change","description":"Email or SMS provider changes sending limits, required authentication (DMARC/DKIM), or carrier filtering rules.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["Gmail announces DMARC requirements for bulk senders","Twilio updates A2P 10DLC registration requirements"],"impacted_roles":["Marketing","Engineering","Growth"],"vendors":["Google Workspace","Twilio","SendGrid","Mailchimp","Klaviyo"],"detection_urls":["https://support.google.com/a/answer/81126","https://www.twilio.com/docs/messaging/compliance"],"created_at":"2026-04-04T18:22:06.997072+00:00","updated_at":"2026-04-04T18:22:06.997072+00:00"},{"id":"OPS-009","category":"operational","title":"Logistics API or Shipping Rate Change","description":"Carrier or logistics platform changes API structure, rate calculations, or label generation.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"90–180 days","examples":["FedEx API v2 deprecation","UPS changes dimensional weight formula"],"impacted_roles":["Ops","Engineering","Finance"],"vendors":["FedEx","UPS","USPS","ShipBob","EasyPost"],"detection_urls":["https://developer.fedex.com/api/en-us/get-started/whats-new.html"],"created_at":"2026-04-04T18:22:07.071842+00:00","updated_at":"2026-04-04T18:22:07.071842+00:00"},{"id":"OPS-010","category":"operational","title":"Payroll or HR Platform Compliance Update","description":"Payroll vendor updates tax tables, compliance rules, or benefits integration requirements.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["Gusto updates W-2 filing API structure","ADP changes direct deposit routing format"],"impacted_roles":["HR","Finance","Engineering"],"vendors":["Gusto","ADP","Rippling","Paychex","QuickBooks Payroll"],"detection_urls":[],"created_at":"2026-04-04T18:22:07.163095+00:00","updated_at":"2026-04-04T18:22:07.163095+00:00"},{"id":"OPS-011","category":"operational","title":"Ad Platform Targeting or Attribution Change","description":"Advertising platform changes audience targeting, attribution windows, or conversion tracking.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["Meta removes 28-day attribution window","Google Ads deprecates similar audiences"],"impacted_roles":["Marketing","Growth","Finance"],"vendors":["Meta Ads","Google Ads","TikTok Ads","LinkedIn Ads"],"detection_urls":["https://developers.facebook.com/docs/marketing-api/changelog/","https://developers.google.com/google-ads/api/docs/release-notes"],"created_at":"2026-04-04T18:22:07.235195+00:00","updated_at":"2026-04-04T18:22:07.235195+00:00"},{"id":"OPS-012","category":"operational","title":"Database or Infrastructure Service Sunset","description":"Cloud or DB provider announces end-of-life for a specific service, instance type, or runtime.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"6–12 months","examples":["AWS Lambda deprecates Node.js 14 runtime","Heroku removes free dynos"],"impacted_roles":["Engineering","DevOps","CTO"],"vendors":["AWS","Heroku","GCP","Azure","Vercel"],"detection_urls":["https://docs.aws.amazon.com/lambda/latest/dg/lambda-runtimes.html"],"created_at":"2026-04-04T18:22:07.2905+00:00","updated_at":"2026-04-04T18:22:07.2905+00:00"},{"id":"PRICE-001","category":"pricing","title":"Payment Processing Fee Increase","description":"Vendor raises per-transaction fees, interchange rates, or monthly minimums on payment processing.","risk_level":"high","detection_method":"pricing_page_diff","typical_lead_time":"0–30 days","examples":["Stripe increases card processing from 2.9%+30¢ to 3.2%+35¢","PayPal adds new cross-border fee tier"],"impacted_roles":["CFO","Finance","Founder"],"vendors":["Stripe","PayPal","Braintree","Square","Chargebee","Recurly"],"detection_urls":["https://stripe.com/pricing","https://www.paypal.com/us/business/paypal-business-fees"],"created_at":"2026-04-04T18:22:05.485613+00:00","updated_at":"2026-04-04T18:22:05.485613+00:00"},{"id":"PRICE-002","category":"pricing","title":"SaaS Subscription Tier Restructuring","description":"Vendor restructures pricing tiers, moves features between plans, or removes grandfathered pricing.","risk_level":"high","detection_method":"pricing_page_diff","typical_lead_time":"30–90 days notice","examples":["HubSpot moves Marketing Hub contacts limit from 10K to 2K on Starter","Salesforce retires legacy SKUs"],"impacted_roles":["CFO","Ops","CTO"],"vendors":["HubSpot","Salesforce","Intercom","Zendesk","Mailchimp"],"detection_urls":["https://www.hubspot.com/pricing","https://www.salesforce.com/editions-pricing/"],"created_at":"2026-04-04T18:22:05.647432+00:00","updated_at":"2026-04-04T18:22:05.647432+00:00"},{"id":"PRICE-003","category":"pricing","title":"Cloud Compute/Storage Pricing Change","description":"AWS, GCP, or Azure changes EC2, S3, Lambda, or egress pricing.","risk_level":"medium","detection_method":"changelog_scrape","typical_lead_time":"0–60 days","examples":["AWS reduces S3 PUT costs","AWS increases EC2 On-Demand pricing in eu-west"],"impacted_roles":["Engineering","FinOps","CTO"],"vendors":["AWS","GCP","Azure"],"detection_urls":["https://aws.amazon.com/pricing/","https://aws.amazon.com/new/"],"created_at":"2026-04-04T18:22:05.737933+00:00","updated_at":"2026-04-04T18:22:05.737933+00:00"},{"id":"PRICE-004","category":"pricing","title":"API Rate Limit or Quota Reduction","description":"Vendor tightens API call limits, reduces free tier quotas, or introduces overage charges.","risk_level":"high","detection_method":"docs_diff","typical_lead_time":"7–30 days","examples":["OpenAI reduces free API quota","Twilio adds new messaging pricing by country"],"impacted_roles":["Engineering","Product","CTO"],"vendors":["Twilio","SendGrid","Mailgun","OpenAI","Google Maps"],"detection_urls":["https://platform.openai.com/docs/guides/rate-limits","https://www.twilio.com/pricing"],"created_at":"2026-04-04T18:22:05.805859+00:00","updated_at":"2026-04-04T18:22:05.805859+00:00"},{"id":"PRICE-005","category":"pricing","title":"Platform Transaction Fee Introduction","description":"Marketplace or platform adds a new transaction fee for services previously free.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"0–60 days","examples":["Shopify adds 2% fee for non-Shopify Payments","App store transaction fee for in-app purchases"],"impacted_roles":["Finance","Founder","Ops"],"vendors":["Shopify","WooCommerce","BigCommerce"],"detection_urls":["https://www.shopify.com/pricing","https://shopify.dev/changelog"],"created_at":"2026-04-04T18:22:05.917358+00:00","updated_at":"2026-04-04T18:22:05.917358+00:00"},{"id":"PRICE-006","category":"pricing","title":"Storage Tier or Data Egress Cost Change","description":"Changes to storage pricing caps, egress costs, or data retention pricing.","risk_level":"medium","detection_method":"pricing_page_diff","typical_lead_time":"30–90 days","examples":["Supabase changes storage egress pricing","Cloudflare adds R2 egress fees"],"impacted_roles":["Engineering","FinOps"],"vendors":["Supabase","Cloudflare","AWS","Vercel","Netlify"],"detection_urls":["https://supabase.com/pricing","https://developers.cloudflare.com/r2/pricing/"],"created_at":"2026-04-04T18:22:05.978615+00:00","updated_at":"2026-04-04T18:22:05.978615+00:00"},{"id":"SEC-001","category":"security","title":"Authentication Method Requirement Change","description":"Vendor mandates new auth method, deprecates API key auth, or requires MFA/SSO.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"30–90 days","examples":["GitHub removes password auth for Git","Okta mandates phishing-resistant MFA"],"impacted_roles":["Engineering","IT","CISO"],"vendors":["GitHub","Okta","Auth0","Google Workspace","AWS"],"detection_urls":["https://github.blog/changelog/","https://developer.okta.com/docs/release-notes/"],"created_at":"2026-04-04T18:22:07.40137+00:00","updated_at":"2026-04-04T18:22:07.40137+00:00"},{"id":"SEC-002","category":"security","title":"TLS/Cipher Suite Requirement Upgrade","description":"Vendor drops support for older TLS versions or cipher suites, requiring client-side upgrades.","risk_level":"high","detection_method":"changelog_scrape","typical_lead_time":"90–180 days","examples":["Stripe drops TLS 1.0/1.1 support","AWS requires TLS 1.2+ for all API calls"],"impacted_roles":["Engineering","DevOps","CISO"],"vendors":["Stripe","AWS","GitHub","Twilio","Cloudflare"],"detection_urls":["https://stripe.com/docs/changelog"],"created_at":"2026-04-04T18:22:07.484633+00:00","updated_at":"2026-04-04T18:22:07.484633+00:00"},{"id":"SEC-003","category":"security","title":"API Key Format or Rotation Policy Change","description":"Vendor changes API key format, adds mandatory rotation, or introduces key scoping requirements.","risk_level":"medium","detection_method":"docs_diff","typical_lead_time":"30–90 days","examples":["Stripe updates publishable key prefix","GitHub changes PAT format to fine-grained tokens"],"impacted_roles":["Engineering","Security","DevOps"],"vendors":["GitHub","Stripe","AWS","SendGrid","Twilio"],"detection_urls":["https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/about-authentication-to-github"],"created_at":"2026-04-04T18:22:07.593684+00:00","updated_at":"2026-04-04T18:22:07.593684+00:00"},{"id":"SEC-004","category":"security","title":"Security Incident or Breach Notification","description":"Vendor discloses a data breach, security incident, or compromise affecting customer data.","risk_level":"high","detection_method":"trust_page_diff","typical_lead_time":"0 days (immediate)","examples":["Okta discloses HAR file exposure","LastPass announces breach of encrypted vaults"],"impacted_roles":["CISO","Legal","CEO"],"vendors":["Okta","LastPass","GitHub","Twilio","Salesforce"],"detection_urls":["https://trust.okta.com/","https://status.stripe.com/"],"created_at":"2026-04-04T18:22:07.667493+00:00","updated_at":"2026-04-04T18:22:07.667493+00:00"},{"id":"SEC-005","category":"security","title":"RBAC/Permission Model Restructuring","description":"Vendor overhauls role-based access control, adding or removing permission scopes.","risk_level":"medium","detection_method":"docs_diff","typical_lead_time":"30–90 days","examples":["AWS IAM policy syntax breaking change","Salesforce profile permission deprecation"],"impacted_roles":["Engineering","IT","CISO"],"vendors":["AWS","Salesforce","Okta","Google Workspace","GitHub"],"detection_urls":["https://docs.aws.amazon.com/IAM/latest/UserGuide/reference_policies_actions-resources-contextkeys.html"],"created_at":"2026-04-04T18:22:07.720361+00:00","updated_at":"2026-04-04T18:22:07.720361+00:00"},{"id":"VENDOR-001","category":"vendor_risk","title":"Vendor Acquisition or Merger Announcement","description":"Key tool is acquired, merged, or undergoes ownership change that may affect roadmap, pricing, or continuity.","risk_level":"high","detection_method":"news_monito