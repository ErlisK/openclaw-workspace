Data"}],["$","p",null,{"children":"We collect product usage data (alert reactions, feature usage, session metadata) to improve the service. This data is aggregated and pseudonymized for analytics."}],["$","h3",null,{"children":"2.5 Security Audit Logs"}],["$","p",null,{"children":"We maintain security audit logs of authentication events, connector changes, and administrative actions. These logs are retained for 90 days and are accessible only to your organization and our security team."}]]}]]}],["$","section",null,{"style":{"marginBottom":"2.5rem"},"children":[["$","h2",null,{"style":{"fontWeight":800,"fontSize":"1.1rem","marginBottom":"0.75rem","paddingBottom":"0.4rem","borderBottom":"1px solid var(--border)"},"children":"3. How We Use Your Data"}],["$","div",null,{"style":{"color":"rgba(255,255,255,0.8)","fontSize":"0.88rem"},"children":[["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Service delivery"}],": Monitor vendor changes and generate risk alerts"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Security"}],": Detect unauthorized access and prevent abuse"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Product improvement"}],": Improve detection accuracy and user experience (aggregated, anonymized)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications"}],": Send alert notifications, weekly briefs, and critical security notices"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal compliance"}],": Comply with applicable laws and respond to lawful requests"]}]]}],["$","p",null,{"children":["We do ",["$","strong",null,{"children":"not"}]," sell your data or use your vendor event data for cross-customer analysis or model training without explicit consent."]}]]}]]}],["$","section",null,{"style":{"marginBottom":"2.5rem"},"children":[["$","h2",null,{"style":{"fontWeight":800,"fontSize":"1.1rem","marginBottom":"0.75rem","paddingBottom":"0.4rem","borderBott