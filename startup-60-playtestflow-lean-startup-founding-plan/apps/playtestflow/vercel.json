{
  "crons": [
    {
      "path": "/api/cron/uptime",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/follow-up",
      "schedule": "0 * * * *"
    },
