{
  "metadata": {
    "project": "ClaimCheck Studio",
    "total_factors": 22,
    "scoring_scale": "1 = minimal/absent, 5 = best-in-class",
    "note": "Scores based on public feature documentation as of 2025. claimcheck_studio = target state."
  },
  "factors": [
    {
      "id": "claim_extraction_quality",
      "name": "Claim Extraction Quality",
      "description": "Ability to identify and extract discrete factual claims from input documents (manuscripts, slides, transcripts)",
      "weight": "critical",
      "claimcheck_target_score": 5,
      "rationale": "Core differentiator — LLM-powered extraction from heterogeneous inputs"
    },
    {
      "id": "evidence_search_depth",
      "name": "Evidence Search Depth (PubMed/CrossRef/Scite coverage)",
      "description": "Breadth and quality of biomedical/scientific database search for supporting evidence",
      "weight": "critical",
      "claimcheck_target_score": 5,
      "rationale": "Multi-database search (PubMed + CrossRef + Scite + Unpaywall) is a core architecture pillar"
    },
    {
      "id": "citation_accuracy",
      "name": "Citation Accuracy",
      "description": "Accuracy and completeness of bibliographic citations produced (DOI, authors, year, journal)",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "Citation bundles with DOIs are a primary deliverable"
    },
    {
      "id": "source_credibility_scoring",
      "name": "Source Credibility Scoring",
      "description": "Automated scoring of source quality (journal impact, retraction status, replication confidence, study type)",
      "weight": "critical",
      "claimcheck_target_score": 5,
      "rationale": "Provenance/confidence scores are a key brand promise"
    },
    {
      "id": "provenance_confidence_scoring",
      "name": "Provenance & Confidence Scoring",
      "description": "Per-claim provenance tracking showing which source supports/contradicts/mentions each claim",
      "weight": "critical",
      "claimcheck_target_score": 5,
      "rationale": "Maps directly to scite's 'smart citations' but extended to output content pipeline"
    },
    {
      "id": "paywall_access_handling",
      "name": "Paywall Access Handling",
      "description": "Ability to access full-text articles behind paywalls via institutional connectors, Unpaywall, or OA sources",
      "weight": "high",
      "claimcheck_target_score": 4,
      "rationale": "Unpaywall integration + optional institutional connectors"
    },
    {
      "id": "hallucination_risk_mitigation",
      "name": "Hallucination Risk Mitigation",
      "description": "Active measures to detect and flag AI-generated content that lacks supporting evidence",
      "weight": "critical",
      "claimcheck_target_score": 5,
      "rationale": "Flagging unsupported assertions is a core value prop and brand promise"
    },
    {
      "id": "output_format_variety",
      "name": "Output Format Variety",
      "description": "Range of content formats generated from evidence (tweet, LinkedIn thread, blog post, slide copy, explainer)",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "Channel-ready multi-format output is a key differentiator vs pure research tools"
    },
    {
      "id": "tone_literacy_adaptation",
      "name": "Tone & Literacy-Level Adaptation",
      "description": "Ability to adjust content tone, reading level, and style for different audiences (lay public, clinicians, policymakers)",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "Science communication requires audience-specific translation"
    },
    {
      "id": "compliance_regulatory_tools",
      "name": "Compliance / Regulatory Phrasing Tools",
      "description": "Features for enforcing regulatory-compliant phrasing, FDA/EMA guidelines, MLR review workflow",
      "weight": "high",
      "claimcheck_target_score": 4,
      "rationale": "Compliance agent for pharma/regulated industries is a planned premium tier"
    },
    {
      "id": "peer_review_human_oversight",
      "name": "Peer Review / Human Oversight Layer",
      "description": "Built-in human review workflow (expert sign-offs, microtask community, reputation system)",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "Vetted peer-review microcommunity is a core unique feature"
    },
    {
      "id": "audit_trail",
      "name": "Audit Trail",
      "description": "Detailed, exportable audit log showing who reviewed what, when, with what source evidence",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "Required for enterprise/pharma compliance SLA"
    },
    {
      "id": "citation_bundle_export",
      "name": "Citation Bundle Export",
      "description": "Downloadable package of DOIs, plain-language summaries, source excerpts, and snapshot PDFs",
      "weight": "high",
      "claimcheck_target_score": 5,
      "rationale": "The 'citation bundle' is a named product deliverable"
    },
    {
      "id": "cms_integration",
      "name": "CMS Integration",
      "description": "Native integration with content management systems (WordPress, HubSpot, Contentful, etc.)",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Export to CMSs is mentioned in the product spec"
    },
    {
      "id": "api_access",
      "name": "API Access",
      "description": "Programmatic API for developers to integrate evidence-checking into their own workflows",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Enterprise and institutional connector strategy"
    },
    {
      "id": "team_collaboration",
      "name": "Team Collaboration",
      "description": "Multi-user workspace, commenting, role management, shared libraries",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Target enterprise customers require team workflows"
    },
    {
      "id": "brand_voice_customization",
      "name": "Brand Voice Customization",
      "description": "Ability to train the tool on organization-specific tone, terminology, and style guides",
      "weight": "medium",
      "claimcheck_target_score": 3,
      "rationale": "Important for institutional clients but secondary to evidence features"
    },
    {
      "id": "real_time_evidence_updates",
      "name": "Real-Time Evidence Updates",
      "description": "Alerts or automatic re-scoring when source evidence changes (new papers, retractions, meta-analyses)",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Science is live; retraction monitoring is a differentiator"
    },
    {
      "id": "pricing_accessibility",
      "name": "Pricing Accessibility",
      "description": "Availability of affordable plans for individual researchers, academics, and science communicators",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Need freemium tier to build bottom-up adoption before enterprise sales"
    },
    {
      "id": "onboarding_ease",
      "name": "Onboarding Ease",
      "description": "Time to first value: how quickly a new user can get meaningful output",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Must be significantly easier than Veeva/MLR tools to capture the mid-market"
    },
    {
      "id": "enterprise_sla_support",
      "name": "Enterprise SLA Support",
      "description": "SLAs, dedicated support, security certifications (SOC2, HIPAA), uptime guarantees",
      "weight": "medium",
      "claimcheck_target_score": 4,
      "rationale": "Pharma and health system buyers require enterprise security posture"
    },
    {
      "id": "microtask_community_features",
      "name": "Microtask Community Features",
      "description": "Paid expert review marketplace, reputation badges, task routing, incentive mechanisms",
      "weight": "medium",
      "claimcheck_target_score": 5,
      "rationale": "Unique feature — no competitor has a built-in paid expert microtask community"
    }
  ],
