      "export": {
        "format": "mp4",
        "codec": "libx264",
        "preset": "fast",
        "crf": 22,
        "fps": 30,
        "audio_codec": "aac",
        "audio_bitrate_kbps": 128,
        "audio_sample_rate_hz": 44100,
        "max_duration_sec": 60,
        "max_file_size_mb": 50,
        "pixel_format": "yuv420p"
      }
    },

