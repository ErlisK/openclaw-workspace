          "font_size_px": 108,
          "line_height_multiplier": 1.15,
          "text_color": "#FFFFFF",
          "text_align": "center",
          "max_words_per_line": 1,
          "max_lines_visible": 2,
          "highlight_mode": "current_word_color",
          "highlight_color": "#FFDC00",
          "outline": {
            "enabled": true,
            "color": "#000000",
            "width_px": 6
          },
          "animation": {
            "type": "kinetic_bounce",
            "timing": "word_sync",
            "active_word_scale": 1.2,
            "active_word_color": "#FFDC00",
            "transition_ms": 50,
            "silence_hold_ms": 400,
            "note": "silence_hold_ms: caption freezes for silence gaps — critical for comedy timing"
          }
        },

        "lower_third": {
          "enabled": false
        },

        "progress_bar": {
          "enabled": true,
          "z_index": 50,
          "top_px": 1880,
          "left_px": 0,
          "width_px": 1080,
          "height_px": 10,
          "track": { "color": "#FFFFFF15" },
          "fill": { "color": "#FFDC00", "animation": "realtime_sync" }
        }
      },

      "clip_rules": {
        "punchline_buffer_sec": 1.5,
        "note": "Extend clip end by 1.5s after last scored PUNCHLINE_MOMENT to preserve silence+reaction"
      },

      "export": {
        "format": "mp4",
        "codec": "libx264",
        "preset": "fast",
        "crf": 22,
        "fps": 30,
        "audio_codec": "aac",
        "audio_bitrate_kbps": 128,
        "max_duration_sec": 60,
        "max_file_size_mb": 50,
        "pixel_format": "yuv420p"
      }
    }
  },

  "platform_export_rules": {
