{
  "$schema": "https://clipspark.io/schemas/template/v0.2.json",
  "$comment": "ClipSpark Clip Template Schema v0.2 — canonical reference for rendering pipeline",
  "schema_version": "0.2.0",
  "created": "2026-04-09",
  "changelog": [
    "v0.1: initial 3-template schema (default_vertical, linkedin_professional, tiktok_bold)",
    "v0.2: added lower_third, progress_bar, waveform_layer, thumbnail spec, full font registry, color tokens, per-platform safe-zones, 5 production templates"
  ],

  "_design_principles": [
    "1. Every field maps to a concrete FFmpeg/Canvas rendering parameter",
    "2. Templates are additive — a niche_override only changes what it specifies",
    "3. All sizes in px at 1080×1920 (9:16 base); scale linearly for other resolutions",
    "4. Colors as 6-digit hex or 8-digit hex (last 2 = alpha)",
    "5. Time values in seconds (float) unless named _ms"
  ],

  "font_registry": {
    "_comment": "Available fonts. 'system' fonts are bundled with the renderer; 'google' require fetch at build.",
    "inter_bold": {
      "family": "Inter",
      "weight": 700,
      "style": "normal",
      "source": "google",
      "fallback": "LiberationSans-Bold"
    },
    "inter_black": {
      "family": "Inter",
      "weight": 900,
      "style": "normal",
      "source": "google",
      "fallback": "DejaVuSans-Bold"
    },
    "inter_regular": {
      "family": "Inter",
      "weight": 400,
      "style": "normal",
      "source": "google",
      "fallback": "LiberationSans-Regular"
    },
    "open_sans_bold": {
      "family": "Open Sans",
      "weight": 700,
      "style": "normal",
      "source": "system",
      "fallback": "OpenSans-Bold"
    },
    "mono_bold": {
      "family": "DejaVu Sans Mono",
      "weight": 700,
      "style": "normal",
      "source": "system",
      "fallback": "DejaVuSansMono-Bold"
    }
  },

  "color_tokens": {
    "_comment": "Brand-level color palette. Templates reference these by token name.",
    "brand_primary": "#6366F1",
    "brand_secondary": "#A855F7",
    "brand_accent_tiktok": "#FF3E9D",
    "brand_accent_yellow": "#FFDC00",
    "brand_accent_orange": "#F97316",
    "neutral_black": "#0A0A0A",
    "neutral_dark": "#1A1A2E",
    "neutral_gray": "#3D3D3D",
    "neutral_light": "#F8F8FF",
    "neutral_white": "#FFFFFF",
    "caption_outline": "#000000CC",
    "progress_bar_fill": "#6366F1",
    "progress_bar_track": "#FFFFFF33",
    "lower_third_bg": "#000000B3",
    "lower_third_accent": "#6366F1"
  },

  "safe_zones": {
    "_comment": "Platform-specific UI elements that overlap the video. Keep text/branding outside these zones.",
    "tiktok": {
      "top_percent": 8,
      "bottom_percent": 22,
      "right_percent": 12,
      "note": "Right column: like/comment/share buttons. Bottom: caption area."
    },
    "instagram_reels": {
      "top_percent": 8,
      "bottom_percent": 20,
      "right_percent": 10
    },
    "youtube_shorts": {
      "top_percent": 5,
      "bottom_percent": 15,
      "right_percent": 0
    },
    "linkedin": {
      "top_percent": 5,
      "bottom_percent": 10,
      "right_percent": 0
    }
  },

  "templates": {

    "podcast_pro": {
      "id": "podcast-pro-v02",
      "name": "Podcast Pro",
      "description": "Universal default for solo podcasters. Dark canvas, bold centered captions, optional waveform, clean lower-third. Works on all platforms.",
      "preset_label": "Podcast Pro",
      "use_cases": ["podcast", "coaching", "founder", "education"],
      "platforms": ["youtube_shorts", "instagram_reels", "tiktok", "linkedin"],
      "csat_preferred_by": ["marcus", "tom", "dev", "raj"],

      "canvas": {
        "aspect_ratio": "9:16",
        "width_px": 1080,
        "height_px": 1920,
        "background": {
          "type": "gradient",
          "gradient_type": "linear",
          "gradient_start_color": "#0A0A0A",
          "gradient_end_color": "#1A1A2E",
          "gradient_angle_deg": 180
        }
      },

      "layers": {
        "video": {
          "enabled": true,
          "z_index": 10,
          "position": "top_center",
          "top_px": 80,
          "width_px": 1080,
          "height_px": 1080,
          "corner_radius_px": 0,
          "reframe_mode": "auto_speaker_track",
          "fallback_reframe": "center_crop",
          "aspect_ratio_fill": "cover",
          "opacity": 1.0
        },

        "caption": {
          "enabled": true,
          "z_index": 30,
          "position": "absolute",
          "top_px": 1200,
          "left_px": 60,
          "width_px": 960,
          "font": "inter_bold",
          "font_size_px": 56,
          "line_height_multiplier": 1.35,
          "text_color": "#FFFFFF",
          "text_align": "center",
          "max_words_per_line": 4,
          "max_lines_visible": 2,
          "highlight_mode": "keyword_color",
          "highlight_color": "#A855F7",
          "highlight_weight": "inter_black",
          "outline": {
            "enabled": true,
            "color": "#000000CC",
            "width_px": 4
          },
          "shadow": {
            "enabled": true,
            "color": "#00000088",
            "blur_px": 6,
            "offset_x_px": 0,
            "offset_y_px": 3
          },
          "background_pill": {
            "enabled": false,
            "color": "#00000000",
            "radius_px": 12,
            "padding_x_px": 20,
            "padding_y_px": 10
          },
          "animation": {
            "type": "word_pop",
            "timing": "word_sync",
            "active_word_scale": 1.08,
            "active_word_color": "#FFDC00",
            "transition_ms": 80
          }
        },

        "lower_third": {
          "enabled": true,
          "z_index": 40,
          "position": "absolute",
          "top_px": 1600,
          "left_px": 0,
          "width_px": 1080,
          "height_px": 120,
          "background": {
            "type": "solid",
            "color": "#000000B3"
          },
          "accent_bar": {
            "enabled": true,
            "side": "left",
            "width_px": 8,
            "color": "#6366F1"
          },
          "show_name": {
            "enabled": true,
            "text_source": "creator_name",
            "font": "inter_bold",
            "font_size_px": 36,
            "color": "#FFFFFF",
            "left_px": 40,
            "top_px": 20
          },
          "show_label": {
            "enabled": true,
            "text_source": "episode_title_short",
            "font": "inter_regular",
            "font_size_px": 28,
            "color": "#AAAAAA",
            "left_px": 40,
            "top_px": 68
          },
          "logo": {
            "enabled": false,
            "src": null,
            "width_px": 72,
            "height_px": 72,
            "right_px": 40,
            "vertical_center": true
          },
          "animation": {
            "type": "slide_up",
            "trigger": "clip_start",
            "duration_ms": 300,
            "delay_ms": 500
          }
        },

        "progress_bar": {
          "enabled": true,
          "z_index": 50,
          "position": "absolute",
          "top_px": 1720,
          "left_px": 0,
          "width_px": 1080,
          "height_px": 6,
          "track": {
            "color": "#FFFFFF22",
            "border_radius_px": 3
          },
          "fill": {
            "color": "#6366F1",
            "border_radius_px": 3,
            "animation": "realtime_sync"
          },
          "dot_indicator": {
            "enabled": false,
            "radius_px": 8,
            "color": "#FFFFFF"
          }
        },

        "waveform": {
          "enabled": false,
          "z_index": 20,
          "position": "absolute",
          "top_px": 1150,
          "left_px": 60,
          "width_px": 960,
          "height_px": 80,
          "style": "bar",
          "bar_count": 60,
          "bar_width_px": 6,
          "bar_gap_px": 10,
          "color_active": "#6366F1",
          "color_inactive": "#FFFFFF33",
          "animation": "realtime_amplitude",
          "note": "Enable for audio-only episodes where video layer is absent"
        }
      },

      "thumbnail": {
        "enabled": true,
        "style": "split_face_text",
        "width_px": 1080,
        "height_px": 1920,
        "background_gradient": ["#1A1A2E", "#0A0A2E"],
        "headline_font": "inter_black",
        "headline_size_px": 80,
        "headline_color": "#FFFFFF",
        "headline_max_lines": 3,
        "accent_color": "#6366F1",
        "creator_name_font": "inter_bold",
        "creator_name_size_px": 42,
        "creator_name_color": "#A855F7"
      },

      "export": {
        "format": "mp4",
        "codec": "libx264",
        "preset": "fast",
        "crf": 23,
        "fps": 30,
        "audio_codec": "aac",
        "audio_bitrate_kbps": 128,
        "audio_sample_rate_hz": 44100,
        "max_duration_sec": 60,
        "max_file_size_mb": 50,
        "pixel_format": "yuv420p"
      }
    },

