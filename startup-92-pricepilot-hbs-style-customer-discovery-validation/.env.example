# PricePilot — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# All variables marked REQUIRED must be set or the app will not function.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co           # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...                               # REQUIRED
SUPABASE_SERVICE_ROLE_KEY=eyJh...                                   # REQUIRED — never expose client-side

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                                        # REQUIRED
STRIPE_WEBHOOK_SECRET=whsec_...                                      # REQUIRED — from Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...                      # REQUIRED — safe for client

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte hex string used to AES-256-GCM encrypt stored Stripe keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-char-string                              # REQUIRED

# ── Auth / Admin ──────────────────────────────────────────────────────────────
# Bearer token for /api/admin/* endpoints
ADMIN_SECRET=your-random-secret                                     # REQUIRED

# ── Visitor Tracking (A/B experiments) ───────────────────────────────────────
# HMAC-SHA-256 secret for signing pp_vid cookies on /x/[slug] pages
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: if missing, visitor tracking is disabled entirely (hard fail, no fallback)
PP_VID_SECRET=your-random-secret                                    # REQUIRED

# ── Rate Limiting (distributed) ───────────────────────────────────────────────
# Upstash Redis — free tier sufficient. Without these, rate limiting falls back
# to per-instance in-memory counters (NOT recommended in production on Vercel).
# Sign up at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io            # STRONGLY RECOMMENDED
UPSTASH_REDIS_REST_TOKEN=AX...                                      # STRONGLY RECOMMENDED
