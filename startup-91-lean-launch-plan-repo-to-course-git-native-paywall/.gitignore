# TeachRepo Monorepo — .gitignore

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local
!.env.example

# Testing
coverage/
playwright-report/
test-results/
*.snap

# Turbo
.turbo/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Vercel
.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Type declarations
*.d.ts
!packages/types/src/*.d.ts
