NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=https://teachrepo.com

# Analytics — Optional PostHog integration
# Leave blank to disable PostHog (Supabase events table is always the primary sink)
POSTHOG_KEY=                        # Server-side PostHog API key (phc_...)
POSTHOG_HOST=https://app.posthog.com  # Or your self-hosted PostHog URL
NEXT_PUBLIC_POSTHOG_KEY=            # Optional: same key for client-side identify() calls
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Security
IP_HASH_SALT=your-random-salt-string  # Used for daily-rotating IP hashing
