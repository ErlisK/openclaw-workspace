{
  "name": "teachrepo",
  "version": "0.1.0",
  "private": true,
  "description": "TeachRepo monorepo \u2014 convert a GitHub repo into a paywalled course site",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + 2>/dev/null; true",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\" --ignore-path .gitignore",
    "db:seed": "tsx scripts/seed-demo.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.3",
    "typescript": "^5.4.2",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ErlisK/openclaw-workspace",
    "directory": "startup-91-lean-launch-plan-repo-to-course-git-native-paywall"
  },
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0"
  }
}
